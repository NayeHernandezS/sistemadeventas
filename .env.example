# Copia a .env en la raiz: cp .env.example .env
# Guia completa: deploy/DEPLOY.md

# --- Base de datos ---
DB_URL=jdbc:mysql://db:3306/java_curso?serverTimezone=America/Mexico_City
DB_USER=ventas
DB_PASSWORD=16Crepusculo
# Migraciones al arrancar (Flyway). false = solo SQL manual
FLYWAY_ENABLED=true

# --- URL publica HTTPS (sin barra final) ---
# Produccion: https://ventas.tudominio.com
# Local + Mercado Pago (renovacion automatica): tunel HTTPS, NO uses localhost
#   chmod +x deploy/scripts/tunel-local.sh && ./deploy/scripts/tunel-local.sh
#   (actualiza APP_BASE_URL en .env y reinicia la app)
APP_BASE_URL=https://ventas.tudominio.com

# --- SMTP (correo transaccional) ---
# Gmail / Google Workspace (requiere contraseña de aplicacion):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_STARTTLS=true  SMTP_SSL=false
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASSWORD=SG.xxx
# Amazon SES:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false
MAIL_FROM=noreply@tudominio.com

# --- Mercado Pago (Mexico) — suscripciones SaaS ---
# Produccion: APP_USR-... | Pruebas: TEST-... (developers.mercadopago.com)
# Webhook: https://TU-DOMINIO/api/mercadopago/notificaciones
# Checklist: deploy/CHECKLIST_MERCADOPAGO.md
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- CFDI Facturama (Mexico) ---
# Cada negocio conecta su Facturama en Mi perfil (admin). Variables globales = fallback demo/plataforma.
# Clave para cifrar contrasenas Facturama por tenant (obligatoria en produccion):
CFDI_ENCRYPTION_KEY=genera-una-clave-larga-y-aleatoria-de-al-menos-32-caracteres
# Opcional: credenciales globales de respaldo (sandbox de la plataforma)
CFDI_ENABLED=false
CFDI_FACTURAMA_USER=
CFDI_FACTURAMA_PASSWORD=
CFDI_FACTURAMA_SANDBOX=true

# --- Opcional ---
# MERCADOPAGO_ENABLED=true
# APP_UPLOADS_DIR=/app/uploads
